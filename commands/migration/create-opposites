#!/usr/bin/env bash

# DTM Migrations - create-opposites command
# Create Opposite References for DTM Assets

# import shared functions

# shellcheck source=/dev/null
source "$(dirname "$0")/../_shared/helper"
source "$(dirname "$0")/../_shared/constants"

# Stop on unexpected errors
set -e


# Help text
help() {
    cat <<EOF
Create Opposite references for DTM Assets with c8y_LinkedSeries fragment.

Usage:
    c8y dtm migration create-opposites [args...]

Description:
    Creates opposite references for all Assets that have the c8y_LinkedSeries fragment. 
    For each linked series, an opposite reference will be created as ChildAddition of the linked device using the 
    /assets/{id}/linkedSeries/{fragment}/{series}/opposite endpoint.


Flags:
    -h, --help                 Show this help message
    --removeMissingSourceId    If set, remove non-existing source.id from the c8y_LinkedSeries. 
    --dryRun                   Show what would be done, without making any changes.

Examples:
    c8y dtm migration create-opposites --removeMissingSourceId

Requirements:
    - go-c8y-cli authenticated session
    - jq for JSON processing
EOF
}

# Default values
REMOVE_MISSING_SOURCE_ID=false
DRY_RUN=false

# Parse arguments
while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)
            help
            exit 0
            ;;
        --removeMissingSourceId)
            REMOVE_MISSING_SOURCE_ID=true
            shift
            ;;
        --dryRun)
            DRY_RUN=true
            shift
            ;;
        *)
            error "Unknown option: $1"
            help
            exit 1
            ;;
    esac
done

check_prerequisites

FILTER_QUERY="has(${LINKED_SERIES_FRAGMENT})"
EXTRA_SELECT_FIELDS="${LINKED_SERIES_FRAGMENT}"
assets_with_linked_series=$(load_all_assets)

if is_empty_result_set "$assets_with_linked_series" ; then
    info "No assets to handle. Exiting."
    exit 0
fi

total_collected=$(count_lines "$assets_with_linked_series")
info "Server returned $total_collected assets with linked series..."

#If we don't have any assets with linked series to handle, we can exit early.
if [ "$total_collected" -eq 0 ]; then
    info "No assets with linked series to process. Exiting."
    exit 0
fi

echo "$assets_with_linked_series" | jq -c '.' | while IFS= read -r asset; do
    asset_id=$(echo "$asset" | jq -r '.id')

    echo "$asset" | jq -c '.c8y_LinkedSeries[]' | while IFS= read -r series; do
        fragment_name=$(echo "$series" | jq -r '.fragment')
        series_name=$(echo "$series" | jq -r '.series')

        theEndpoint="/assets/$asset_id/linkedSeries/$fragment_name/$series_name/opposite"
        if [ "$REMOVE_MISSING_SOURCE_ID" = "true" ]; then
            theEndpoint="$theEndpoint?removeMissingSourceId=true"
        fi
        withDryRun=""
        if [ "$DRY_RUN" = "true" ]; then
            withDryRun="--dry"
        fi
        
        info "---------------------------------------------"
        info "CALLING: c8y api PUT $theEndpoint $withDryRun"
        _result=$(c8y api PUT "$theEndpoint" $withDryRun)
        info "---------------------------------------------"

    done
done

success "Completed."

exit 0
